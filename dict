#!/usr/bin/python3

from pathlib import Path
from urllib.parse import quote
from dataclasses import dataclass, asdict
import requests
import sys
import subprocess
import json
import os

enabled_caching=True
show_related=False
debug=False
limit=None

DICTIONARY_KEY = os.environ["DICTIONARY_KEY"]
SYNONYMS_KEY = os.environ["SYNONYMS_KEY"]

try:
    GLOW_INSTALLED = subprocess.check_output(['which', 'glow']).strip() != ''
except subprocess.CalledProcessError as e:
    e.add_note("Glow is not installed")
    GLOW_INSTALLED = False

try:
    AI_INSTALLED = subprocess.check_output(['which', 'ai']).strip() != ''
except subprocess.CalledProcessError as e:
    e.add_note("ai is not installed")
    AI_INSTALLED = False

class Cache:
    _instance = None

    cache_file = Path.home() / ".cache/dict" / "lookups" # ~/.cache/dict/lookups
    cache_file.parent.mkdir(parents=True, exist_ok=True)

    cache: dict[str, list[dict]] = {}

    def __new__(cls, *args, **kwargs) -> "Cache":
        if cls._instance is None:
            cls._instance = super().__new__(cls)
            cls._instance.load()

        return cls._instance

    def load(self):
        if self.cache_file.exists():
            cache = json.loads(self.cache_file.read_text())
        else:
            cache = {}

        self.cache = cache

        return cache

    def save(self):
        self.cache_file.write_text(json.dumps(self.cache))

    def set(self, word: str, synonyms: list[dict]):
        self.cache[word] = synonyms

        return synonyms

    def get(self, word: str) -> list[dict] | None:
        return self.cache.get(word)

    def clear(self):
        self.cache = {}
        self.save()

@dataclass
class SynonymResult:
    word: str
    part_of_speech: str
    definitions: list[str]
    syns: list[str]
    related: list[str]
    near_antonyms: list[str]
    antonyms: list[str]

    @staticmethod
    def _flatten_word_lists(nested: list) -> list[str]:
        """Flatten lists of dicts like [[ {"wd": "home"}, {"wd": "abode"} ], ...] into a plain list of strings."""
        return [
            entry.get("wvrs", [{}])[0].get("wva", entry["wd"])  # prefer variant form if present
            if entry.get("wvrs") else entry["wd"]
            for group in nested
            for entry in group
        ]

    @classmethod
    def from_api_entry(cls, entry: dict) -> "SynonymResult":
        senses = entry.get("def", [{}])[0].get("sseq", [])

        syns, related, near_antonyms = [], [], []
        for sense_block in senses:
            for _, sense in sense_block:
                syns      += cls._flatten_word_lists(sense.get("syn_list",  []))
                related   += cls._flatten_word_lists(sense.get("rel_list",  []))
                near_antonyms += cls._flatten_word_lists(sense.get("near_list", []))

        return cls(
            word=entry["hwi"]["hw"],
            part_of_speech=entry.get("fl", "unknown"),
            definitions=entry.get("shortdef", []),
            syns=syns,
            related=related,
            near_antonyms=near_antonyms,
            antonyms=entry.get("meta", {}).get("ants", []),
        )

    @classmethod
    def from_dict_api_entry(cls, entry: dict) -> "SynonymResult":
        return cls(
            word=entry["hwi"]['hw'],
            part_of_speech=entry.get('fl', 'unknown'),
            definitions=entry.get("shortdef", []),
            syns=[],
            related=[],
            near_antonyms=[],
            antonyms=[],
        )

    def to_dict(self) -> dict:
        return asdict(self)

    def __str__(self) -> str:
        lines = [f"# {self.word.upper()}  ({self.part_of_speech})",]

        # Escape asterisks in the word for glow.
        if '*' in self.word:
            safe_word = self.word.replace('*', r'\*')
            lines.append(safe_word)

        if self.definitions:
            if len(self.definitions) > 1:
                lines.append("## Definitions:")
                lines += [f"  {i+1}. {d}" for i, d in enumerate(self.definitions)]
            else:
                lines.append(f"## Definition:\n{self.definitions[0]}")
        if self.syns:
            lines.append(f"\n## Synonyms:\n  {', '.join(self.syns)}")
        if self.related and show_related:
            lines.append(f"\n## Related words:\n  {', '.join(self.related)}")

        return "\n".join(lines)

def lookup_synonyms(word: str, ref: str = "thesaurus") -> list[SynonymResult]:
    if debug:
        print("[DEBUG]: Looking up synonyms for", word)

    response = requests.get(
        f"https://dictionaryapi.com/api/v3/references/{quote(ref)}/json/{quote(word)}?key={quote(SYNONYMS_KEY)}"
    )

    response.raise_for_status()
    response = response.json()

    # The API returns an empty array if the word is not found.
    # We put the first word back in the array so that we can use the same code for both cases.
    if not isinstance(response, list) or len(response) == 0:
        response = [word]

    # The API returns an array of suggestions if the word is not found.
    if isinstance(response[0], str):
        # If we can't find the word, try looking it up in the dictionary.
        if debug:
            print("[DEBUG]: Couldn't find word in thesaurus, trying dictionary")

        return lookup_dictionary(word)

    return [SynonymResult.from_api_entry(entry) for entry in response]

def lookup_dictionary(word: str, ref: str = "collegiate") -> list[SynonymResult]:
    response = requests.get(
        f"https://www.dictionaryapi.com/api/v3/references/{quote(ref)}/json/{quote(word)}?key={quote(DICTIONARY_KEY)}"
    )

    response.raise_for_status()
    response = response.json()

    # The API returns an array of suggestions if the word is not found.
    if not isinstance(response, list) or len(response) == 0:
        os.system(f'echo "# {word.upper()}\nNot found and didn\'t return any suggestions" | glow -')
        return []

    if isinstance(response[0], str):
        # If we can't find the word, lookup the first suggestion
        if debug:
            print("[DEBUG]: Couldn't find word in dictionary, trying first suggestion")

        os.system(f'echo "{word.upper()} not found\n## Suggestions:\n {', '.join(response)}\n\nSearching for {response[0]}" | glow -')

        return lookup_dictionary(response[0])

    return [SynonymResult.from_dict_api_entry(entry) for entry in response]

if len(sys.argv) < 2:
    print("Usage: dict <word>")
    sys.exit(1)

cache = Cache()

for i, arg in enumerate(sys.argv[1:]):
    if arg == '--no-cache':
        enabled_caching = False
        continue

    if arg == '--clear-cache' or arg == '--cache-clear':
        cache.clear()
        continue

    if arg == '--show-related' or arg == '-r':
        show_related = True
        continue

    if arg == '--debug' or arg == '-d':
        debug = True
        continue

    if arg == '--limit' or arg == '-l':
        if i + 2 >= len(sys.argv):
            raise ValueError("Limit must be followed by a number")

        limit = int(sys.argv[i + 2])
        continue

word = sys.argv[1].lower()

print(f"\033]0;Dictionary: {word}\007")

def lookup(word: str) -> list[SynonymResult] | None:
    cached_synonyms = cache.get(word)

    if cached_synonyms is not None and enabled_caching:
        if debug:
            print(f"[DEBUG]: Using cached synonyms for {word} ({len(cached_synonyms)} entries)")

        synonyms = [SynonymResult(**synonym) for synonym in cached_synonyms]
    else:
        synonyms = lookup_synonyms(word)

        if enabled_caching:
            cache.set(word, [synonyms.to_dict() for synonyms in synonyms])

            if (len(synonyms) > 0):
                cache.save()
                if debug:
                    print(f"[DEBUG]: Cached {len(synonyms)} synonyms for {word}")

    return synonyms

synonyms = lookup(word)
if synonyms is None:
    sys.exit(0)

# We always want to show the most relevant synonyms first, so reverse the list if we're not limiting the number of results.
if limit is None:
    synonyms.reverse()

# Output with one call to glow.
lines = []
entry_count = len(synonyms)
for index, entry in enumerate(synonyms[:limit]):
    lines.append(str(entry))

    if index < entry_count - 1:
        lines.append(f"\n{'─' * 125}")

content = '\n'.join(lines)
if GLOW_INSTALLED:
    os.system(f'echo "{content}" | glow -w 125 -')
else:
    print(content)

if AI_INSTALLED:
    prompt = (f"Content: {content}\n\n"
              f"Instructions: Write three sentences making use of the word: [{word}] and its variants. "
              f"Use a new line to separate each sentence, starting each with line with a dash. "
              f"Highlight the word with **"
              f"Use British English spelling. ")

    ai_usage_examples = subprocess.check_output(['ai', '--raw', prompt], text=True).strip()
    os.system(f'echo "## Usage Examples\n{ai_usage_examples}" | glow -w 125')